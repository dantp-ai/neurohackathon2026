# Copy this file to .env.local and fill in your values.
# Get these from `supabase status` after running `supabase start`.

EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=<publishable key from supabase status>

# Used only by backend scripts (never exposed to client)
SUPABASE_SERVICE_KEY=<secret key from supabase status>

# OpenRouter — powers voice -> label (clinician labeling + patient check-in).
# Shared hackathon team key. NOTE: rotate/remove after the event (it's committed here).
EXPO_PUBLIC_OPENROUTER_API_KEY=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
